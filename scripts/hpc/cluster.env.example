# RWTH HPC connection info — copy to `cluster.env` (gitignored) and fill in.
# NON-SECRET values only. Never put a password here — use SSH keys (see hpc/README.md).

# Login host (RWTH CLAIX). Confirm the exact hostname from your RWTH account page.
HPC_HOST=login23-1.hpc.itc.rwth-aachen.de
HPC_USER=your_username           # e.g. ab123456

# SLURM project/account you are allowed to charge GPU hours to.
HPC_ACCOUNT=your_project_account # e.g. rwth1234

# GPU partition. On CLAIX-2023 the GPU partition is commonly `c23g` (H100).
# Confirm with `sinfo` once logged in.
HPC_PARTITION=c23g

# Where the project lives on the cluster (your $HOME or $WORK area).
HPC_REMOTE_DIR=$HOME/Drive-VLM
