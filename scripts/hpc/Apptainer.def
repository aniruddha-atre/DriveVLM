Bootstrap: docker
From: pytorch/pytorch:2.4.0-cuda12.1-cudnn9-runtime

# Build a GPU-ready container for training/eval on RWTH HPC.
#
# Build (where you have root/fakeroot — locally or in CI), then copy the .sif to the cluster:
#   apptainer build drive-vlm.sif scripts/hpc/Apptainer.def
#   scp drive-vlm.sif <user>@<host>:~/Drive-VLM/
#
# On the cluster you usually CANNOT build (no root); just `apptainer exec --nv drive-vlm.sif ...`.

%post
    pip install --no-cache-dir \
        transformers>=4.41 \
        pillow>=10.0 \
        numpy>=1.26 \
        tqdm>=4.66 \
        mlflow>=2.12

%environment
    export HF_HUB_DISABLE_TELEMETRY=1
    export PYTHONUNBUFFERED=1

%labels
    project drive-vlm
